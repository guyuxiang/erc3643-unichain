    "full": "npm run deploy && npm run register && npm run verify"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^2.0.0",
    "hardhat": "^2.17.0",
    "typescript": "^5.0.0"
  }
}
