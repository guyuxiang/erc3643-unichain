{
  "name": "erc3643-unichain",
  "version": "1.0.0",
  "description": "ERC-3643 Implementation on Unichain Sepolia",
  "scripts": {
    "compile": "hardhat compile",
    "deploy": "npx hardhat run scripts/full-deploy.ts --network unichain",
    "register": "npx hardhat run scripts/register-investors.ts --network unichain",
    "verify": "npx hardhat run scripts/verify-erc3643.ts --network unichain",
    "full": "npm run deploy && npm run register && npm run verify"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^2.0.2",
    "@nomicfoundation/hardhat-verify": "^3.0.12",
    "hardhat": "^2.28.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
