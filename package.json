{
  "name": "erc3643-unichain",
  "version": "1.0.0",
  "description": "ERC-3643 Implementation on Unichain Sepolia",
  "scripts": {
    "compile": "hardhat compile",
    "deploy": "npx hardhat run scripts/full-deploy.ts --network unichain",
    "register": "npx hardhat run scripts/register-investors.ts --network unichain",
